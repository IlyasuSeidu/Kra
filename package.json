{
  "name": "kra",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "^3.0.1"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.15.4"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "check:critical-coverage": "node scripts/check-critical-coverage.mjs",
    "check:api-env": "node scripts/check-api-env.mjs --target=ci",
    "check:api-env:staging": "node scripts/check-api-env.mjs --target=staging",
    "check:api-env:production": "node scripts/check-api-env.mjs --target=production",
    "check:backend-readiness": "pnpm check:api-env && pnpm --filter @kra/api check:launch-bootstrap",
    "check:api-runtime-imports": "node scripts/check-api-runtime-imports.mjs",
    "check:security-rules": "node scripts/check-security-rules.mjs",
    "ci:verify": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm check:critical-coverage && pnpm check:security-rules && pnpm check:backend-readiness && pnpm build && pnpm check:api-runtime-imports",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.6",
    "zod": "^3.24.1"
  }
}
