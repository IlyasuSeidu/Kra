{
  "name": "@kra/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @kra/shared build && tsc -p tsconfig.build.json",
    "dev": "pnpm --filter @kra/shared build && node --watch dist/server.js",
    "lint": "pnpm --filter @kra/shared build && eslint src",
    "start": "node dist/server.js",
    "test": "pnpm --filter @kra/shared build && vitest run",
    "test:coverage": "pnpm --filter @kra/shared build && vitest run --coverage",
    "typecheck": "pnpm --filter @kra/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kra/shared": "workspace:*",
    "@fastify/rate-limit": "^10.3.0",
    "fastify": "^5.6.1",
    "firebase-admin": "^13.10.0"
  }
}
